FROM php:8.4-fpm-alpine

RUN apk add --no-cache \
    bash \
    libpng-dev \
    libjpeg-turbo-dev \
    freetype-dev \
    libpq-dev \
    oniguruma-dev \
    zip unzip \
    nginx \
    $PHPIZE_DEPS \
    && docker-php-ext-configure gd --with-freetype --with-jpeg \
    && docker-php-ext-install \
        pdo \
        pdo_mysql \
        pdo_pgsql \
        mbstring \
        bcmath \
        pcntl \
        gd \
    && pecl install redis \
    && docker-php-ext-enable redis \
    && apk del $PHPIZE_DEPS \
    && rm -rf /tmp/* /var/cache/apk/* /usr/share/man /usr/src/php

# Ajustes PHP-FPM
RUN sed -i 's|listen = .*|listen = 127.0.0.1:9000|' /usr/local/etc/php-fpm.d/www.conf || true \
    && sed -i 's|listen = .*|listen = 127.0.0.1:9000|' /usr/local/etc/php-fpm.d/zz-docker.conf || true \
    && sed -i 's|listen = .*|listen = 127.0.0.1:9000|' /usr/local/etc/php-fpm.d/docker.conf || true

# Entrypoint
RUN cat <<'EOF' > /usr/local/bin/docker-php-entrypoint-base.sh
#!/bin/sh
set -e

mkdir -p /run/nginx /var/log/nginx /var/lib/nginx/tmp /var/lib/nginx/client_body
chown -R www-data:www-data /run/nginx /var/log/nginx /var/lib/nginx/tmp /var/lib/nginx/client_body
chmod -R 775 /run/nginx /var/log/nginx /var/lib/nginx/tmp /var/lib/nginx/client_body

if ! pgrep php-fpm > /dev/null; then
    echo "🚀 Iniciando PHP-FPM..."
    php-fpm -D || (echo "❌ Erro ao iniciar PHP-FPM" && exit 1)
fi

echo "🚀 Iniciando Nginx..."
exec nginx -g "daemon off;"
EOF

RUN chmod +x /usr/local/bin/docker-php-entrypoint-base.sh

# Composer
COPY --from=composer:latest /usr/bin/composer /usr/bin/composer

# Nginx
RUN mkdir -p /etc/nginx/http.d && \
    rm -rf /etc/nginx/conf.d && \
    rm -f /etc/nginx/http.d/default.conf && \
    ln -sf /dev/stdout /var/log/nginx/access.log && \
    ln -sf /dev/stderr /var/log/nginx/error.log && \
    cat <<'EOF' > /etc/nginx/http.d/default.conf
server {
    listen 80;
    index index.php index.html;
    root /var/www/html/public;

    location / {
        try_files $uri $uri/ /index.php?$query_string;
    }

    location ~ \.php$ {
        include fastcgi_params;
        fastcgi_param SCRIPT_FILENAME $document_root$fastcgi_script_name;
        fastcgi_pass 127.0.0.1:9000;
        fastcgi_read_timeout 300;
        fastcgi_connect_timeout 300;
        fastcgi_send_timeout 300;
    }

    location ~ /\.ht {
        deny all;
    }
}
EOF

EXPOSE 80

ENTRYPOINT ["/usr/local/bin/docker-php-entrypoint-base.sh"]

WORKDIR /var/www/html